    links:[["岡山拠点紹介","https://livinganywherecommons.com/article/guest_house/202307250002/"]] },
  { name:"尾道ゲストハウス いろは荘", pref:"広島", region:"中国", loc:"尾道市・坂の街",
    tags:["個室","地域交流","移住体験","海・島"],
    body:"尾道の坂の上の昭和の下宿屋をそのまま使った全個室の宿。居間が時に「つどい場」に。市の移住定住コンシェルジュも長期滞在向きと紹介。個室内の作業環境は控えめなので集中作業は居間・近隣カフェ併用が現実的。",
    links:[["公式サイト","https://irohasou.com/"]] },
  { name:"江田島 一棟貸し（自然素材の宿）", pref:"広島", region:"中国", loc:"江田島・広島市からアクセス良",
    tags:["個室","海・島","月額/長期割"],
    body:"瀬戸内海に浮かぶ江田島の一棟貸し。木材を多用した心地よい建物で最大6名。Wi-Fi完備でワーケーション・長期滞在に対応。穏やかな田舎暮らしを気軽に体験できる。",
    links:[["旅色","https://tabiiro.jp/yado/theme/ittogashi/ranking/saninsanyo/hiroshima/"]] },
  { name:"uzuhouse（ウズハウス）", pref:"山口", region:"中国", loc:"下関市・関門海峡沿い",
    tags:["コワーキング","個室","地域交流","カフェ/コーヒー","海・島"],
    body:"関門海峡を望む複合施設。ドミトリー・個室（和/洋）・デラックスルームに加え、カフェ＆バー、イベントスペース、シェアオフィスを備える。仕事・滞在・交流が一棟で完結する数少ない宿。",
    links:[["公式サイト","https://uzuhouse.com/"]] },
  { name:"萩ゲストハウス ruco", pref:"山口", region:"中国", loc:"萩市・萩バスセンター圏",
    tags:["個室","地域交流","カフェ/コーヒー"],
