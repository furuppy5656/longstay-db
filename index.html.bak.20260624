<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ロングステイ宿データベース｜全国・独立系</title>
<style>
  :root {
    --ink: #14171c;
    --sub: #696e77;
    --line: #e2e4e8;
    --paper: #eef0f3;
    --card: #ffffff;
    --accent: #1f6f5c;
    --accent-soft: #e0efea;
    --accent-ink: #134237;
    --gold: #a9772a;
    --gold-soft: #f5ebd6;
    --chip: #eef0f3;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-text-size-adjust: 100%; }
  body {
    font-family: -apple-system, "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
    background: var(--paper); color: var(--ink); line-height: 1.65;
    -webkit-font-smoothing: antialiased; padding-bottom: 60px;
  }
  .wrap { max-width: 760px; margin: 0 auto; padding: 0 14px; }

  header { padding: 32px 0 18px; }
  .eyebrow { font-size: 11px; letter-spacing: 0.18em; color: var(--accent); font-weight: 700; margin-bottom: 10px; }
  h1 { font-size: 23px; font-weight: 800; line-height: 1.32; margin-bottom: 12px; letter-spacing: -0.01em; }
  .lede { font-size: 13px; color: var(--sub); line-height: 1.75; }
  .lede b { color: var(--ink); }

  /* Sticky filter bar */
  .controls {
    position: sticky; top: 0; z-index: 20;
    background: var(--paper); padding: 12px 0 10px;
    border-bottom: 1px solid var(--line); margin-bottom: 4px;
  }
  .search-box {
    width: 100%; padding: 11px 14px; font-size: 15px;
    border: 1.5px solid var(--line); border-radius: 10px; background: var(--card);
    color: var(--ink); -webkit-appearance: none;
  }
  .search-box:focus { outline: none; border-color: var(--accent); }
  .filter-group { margin-top: 9px; }
  .filter-label { font-size: 10.5px; font-weight: 700; color: var(--sub); letter-spacing: 0.08em; margin-bottom: 5px; text-transform: uppercase; }
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip {
    font-size: 12px; font-weight: 600; padding: 5px 11px; border-radius: 16px;
    background: var(--chip); color: var(--sub); border: 1px solid transparent;
    cursor: pointer; user-select: none; transition: all .12s;
  }
  .chip:active { transform: scale(0.96); }
  .chip.on { background: var(--accent); color: #fff; }
  .chip.feat.on { background: var(--gold); }
  .count-row {
    display: flex; justify-content: space-between; align-items: center;
    margin: 12px 0 10px; font-size: 12.5px; color: var(--sub);
  }
  .reset { font-size: 12px; color: var(--accent); font-weight: 700; cursor: pointer; background: none; border: none; }

  /* Card */
  .card {
    background: var(--card); border: 1px solid var(--line); border-radius: 13px;
    padding: 15px 15px 13px; margin-bottom: 11px;
  }
  .card.feat { border-color: var(--gold); box-shadow: 0 0 0 1px var(--gold); }
  .c-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .c-name { font-size: 15.5px; font-weight: 800; line-height: 1.35; }
  .c-pref { font-size: 11px; font-weight: 700; color: var(--accent-ink); background: var(--accent-soft); padding: 2px 9px; border-radius: 12px; white-space: nowrap; margin-top: 2px; }
  .c-loc { font-size: 11.5px; color: var(--sub); font-weight: 600; margin: 5px 0 9px; }
  .c-loc::before { content: "📍 "; }
  .c-feat-flag { display: inline-block; font-size: 10px; font-weight: 700; color: #fff; background: var(--gold); padding: 2px 9px; border-radius: 12px; margin-bottom: 8px; }
  .c-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 9px; }
  .ctag { font-size: 10.5px; font-weight: 600; padding: 2px 8px; border-radius: 5px; background: var(--accent-soft); color: var(--accent-ink); }
  .ctag.price { background: var(--gold-soft); color: var(--gold); }
  .c-body { font-size: 12.5px; color: #3d4148; line-height: 1.75; margin-bottom: 11px; }
  .c-links { display: flex; flex-wrap: wrap; gap: 7px; }
  .c-links a { font-size: 12px; font-weight: 700; color: var(--accent); text-decoration: none; border: 1px solid var(--accent); border-radius: 7px; padding: 6px 12px; }
  .c-links a:active { background: var(--accent-soft); }
  .c-links .nolink { font-size: 11.5px; color: var(--sub); padding: 6px 0; }

  .empty { text-align: center; padding: 40px 20px; color: var(--sub); font-size: 13px; display: none; }

  .note { margin-top: 26px; padding: 16px; background: #e4e7ea; border-radius: 12px; font-size: 11.5px; line-height: 1.85; color: #4a4e54; }
  .note b { color: var(--ink); }
  .note p { margin-bottom: 9px; }
  .note p:last-child { margin-bottom: 0; }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="eyebrow">SEARCHABLE DATABASE · DIRECT BOOKING</div>
    <h1>ロングステイ宿データベース<br><span style="font-size:14px;font-weight:700;color:var(--accent)">独立系・直予約・地域とつながる宿（関東 / 九州 / 中国 重点）</span></h1>
    <p class="lede">「たみ」「DELTA HOSTEL」のような、<b>個室があり仕事ができて、地域・地元文化とつながれる</b>宿を中心に収録。<b>地域・県・条件で絞り込み</b>できます。ADDress連携拠点も含みます。料金は調査時点の目安、必ず直接ご確認を。</p>
  </header>

  <div class="controls">
    <input type="text" class="search-box" id="search" placeholder="🔍 宿名・地名・特徴で検索（例：コーヒー、温泉、駅近）">
    <div class="filter-group">
      <div class="filter-label">地域</div>
      <div class="chips" id="region-chips"></div>
    </div>
    <div class="filter-group">
      <div class="filter-label">条件で絞る</div>
      <div class="chips" id="tag-chips"></div>
    </div>
  </div>

  <div class="count-row">
    <span id="count"></span>
    <button class="reset" id="reset">条件をクリア</button>
  </div>

  <div id="list"></div>
  <div class="empty" id="empty">条件に合う宿が見つかりませんでした。条件を緩めてみてください。</div>

  <div class="note">
    <p>※ <b>収録方針</b>：関東・九州・中国地方は各県3施設前後を目安に、個室＋仕事環境＋地域交流の観点で厳選。その他地域は代表例を掲載しています。全国チェーン（ADDress / LivingAnywhere Commons / HafH）は複数県に拠点があります。</p>
    <p>※ <b>「コワーキング」</b>タグは館内に作業スペースがある宿、<b>「個室」</b>は個室タイプの部屋がある宿、<b>「地域交流」</b>はカフェ/バー/イベント等で地元と混ざる仕掛けがある宿です。<b>「ADDress連携」</b>はADDress会員が定額で使える拠点です。</p>
    <p>※ 料金・空室・最低滞在日数・室内デスクの有無などは変動します。長期＋仕事前提なら、予約前にWi-Fi実測速度・室内デスク・オンライン会議できる場所を直接確認するのが確実です。</p>
  </div>

</div>

<script>
const REGIONS = ["関東","九州","中国","東北","北陸","関西","四国","沖縄","甲信越"];
const TAGS = ["コワーキング","個室","地域交流","カフェ/コーヒー","温泉","古民家","海・島","月額/長期割","ADDress連携","移住体験","全国チェーン"];

const DATA = [
  // ===== 関東 =====
  { name:"水戸宿泊交流場", pref:"茨城", region:"関東", loc:"水戸市柳町（水戸駅圏）",
    tags:["コワーキング","地域交流","月額/長期割"],
    body:"Wi-Fi・電源完備のワークスペース併設のゲストハウス。宿泊者は無料で利用可。コワーキングカフェは地元の人も使い、地元と地元外が混ざる仕掛けが随所に。中長期の拠点・ワーケーション向けプランあり。",
    links:[["公式サイト","https://www.mito-shukuhaku-kouryuu-ba.com"]] },
  { name:"ゲストハウス＆コワーキング ほとり", pref:"群馬", region:"関東", loc:"みなかみ町・水上温泉街中心",
    tags:["コワーキング","地域交流","温泉","カフェ/コーヒー","移住体験"],
    body:"水上温泉街の中心にある宿泊＋コワーキング併設施設。地元×移住者×旅行者が交わるハブを志向。デロンギのコーヒー飲み放題カフェとしても利用可。移住検討やローカル旅行にも好適。",
    links:[["群馬県テレワーク情報","https://gunmagurashi.pref.gunma.jp/g_telework/workplace/hotori"],["Instagram","https://www.instagram.com/hotori_minakami/"]] },
  { name:"南房総ワーケーション 一棟貸し群", pref:"千葉", region:"関東", loc:"南房総市・岩井海岸圏",
    tags:["コワーキング","個室","海・島","月額/長期割"],
    body:"1階ホールがコワーキング、2階にWEB会議専用の個室、和室3部屋という構成の一棟貸しなど、仕事と滞在を分けやすい施設が揃う。岩井海岸まで徒歩3分。長期滞在割引あり。自然の中で集中したい人向け。",
    links:[["南房総ワーケーション","https://minamiboso-workation.jp/facilities"]] },
  { name:"ドゥカーレ ガーデンホテル九十九里", pref:"千葉", region:"関東", loc:"九十九里町・ロングビーチ徒歩5分",
    tags:["個室","海・島","月額/長期割"],
    body:"トレーラーハウス・グランピング・ビジネスタイプなど4タイプから選べる宿。全館Wi-Fi完備、独立バスルーム・コーヒーマシン付きの個室タイプあり。海辺でのワーケーションに。",
    links:[["紹介記事","https://icotto.jp/presses/18471"]] },

  // ===== 九州 =====
  { name:"HafH Fukuoka THE LIFE", pref:"福岡", region:"九州", loc:"福岡市・祇園駅 徒歩7分",
    tags:["コワーキング","個室","地域交流","月額/長期割","全国チェーン"],
    body:"多国籍な旅人が交わるデザイナーズゲストハウス＆ホステル。長期滞在者向けの特典付きプランあり。HafH会員の多拠点利用とも親和性が高い。博多中心部で都市インフラが整い、外で作業する選択肢も豊富。",
    links:[["紹介記事","https://aumo.jp/articles/1291762"]] },
  { name:"UNPLAN Fukuoka", pref:"福岡", region:"九州", loc:"福岡市・大濠公園前",
    tags:["コワーキング","個室","カフェ/コーヒー"],
    body:"大濠公園を望む閑静なエリアのホステル。館内にカフェ、電源付きテーブルとWi-Fiを備えた24時間使えるラウンジあり。福岡空港から約15分。個室・ドミトリー両方。",
    links:[["施設情報","https://workation.app/hotels/7nlkVtvUMhChZjCUSlsB0l"]] },
  { name:"体験型民泊 村井屋", pref:"福岡", region:"九州", loc:"香春町・採銅所駅圏",
