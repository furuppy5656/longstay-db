    tags:["個室","地域交流","古民家","全国チェーン","月額/長期割","ADDress連携","移住体験"],
    body:"定額で全国の家を渡り歩ける住まいのサブスク。空き家リノベの一軒家が多く、庭・縁側付きも。JR東日本系（フォルクローロ/ファミリーオ）やBackpackers' Japan（Len/toco./Nui./CITAN）等とも提携。「元地域おこし協力隊家守の家」など地域交流主目的の拠点が多数。",
    links:[["公式サイト","https://address.love/"]] },
  { name:"LivingAnywhere Commons", pref:"全国", region:"九州", loc:"全国各地（福岡・岡山ほか）",
    tags:["コワーキング","個室","地域交流","全国チェーン","月額/長期割","移住体験"],
    body:"全国に拠点を構える宿泊型コワーキング。各拠点にWi-Fi・作業環境を完備。月額の住み放題系プランで多拠点生活に対応。地域の活動・コミュニティとの接点も多い。",
    links:[["公式サイト","https://livinganywherecommons.com/"]] },
];

// ---- Render ----
const state = { region:null, tags:new Set(), q:"" };
const regionChips = document.getElementById('region-chips');
const tagChips = document.getElementById('tag-chips');
const list = document.getElementById('list');
const countEl = document.getElementById('count');
const emptyEl = document.getElementById('empty');

REGIONS.forEach(r => {
  const c = document.createElement('span');
  c.className = 'chip'; c.textContent = r;
  c.onclick = () => { state.region = state.region===r ? null : r; sync(); render(); };
  c.dataset.region = r;
  regionChips.appendChild(c);
});
TAGS.forEach(t => {
  const c = document.createElement('span');
  const feat = (t==="ADDress連携"||t==="全国チェーン");
  c.className = 'chip' + (feat?' feat':''); c.textContent = t;
  c.onclick = () => { state.tags.has(t)?state.tags.delete(t):state.tags.add(t); sync(); render(); };
  c.dataset.tag = t;
  tagChips.appendChild(c);
});

document.getElementById('search').addEventListener('input', e => { state.q = e.target.value.trim().toLowerCase(); render(); });
document.getElementById('reset').onclick = () => {
  state.region=null; state.tags.clear(); state.q="";
  document.getElementById('search').value="";
  sync(); render();
};

function sync(){
  document.querySelectorAll('[data-region]').forEach(c => c.classList.toggle('on', c.dataset.region===state.region));
  document.querySelectorAll('[data-tag]').forEach(c => c.classList.toggle('on', state.tags.has(c.dataset.tag)));
}

function match(item){
  if (state.region && item.region!==state.region) return false;
  for (const t of state.tags) if (!item.tags.includes(t)) return false;
  if (state.q){
    const hay = (item.name+" "+item.pref+" "+item.loc+" "+item.body+" "+item.tags.join(" ")).toLowerCase();
    if (!hay.includes(state.q)) return false;
  }
  return true;
}

function render(){
  const items = DATA.filter(match);
  // featured first
  items.sort((a,b)=> (b.feat?1:0)-(a.feat?1:0));
  list.innerHTML = "";
  items.forEach(item => {
    const card = document.createElement('div');
    card.className = 'card' + (item.feat?' feat':'');
    const links = item.links.map(l => l[1]==="#"
      ? `<span class="nolink">${l[0]}</span>`
      : `<a href="${l[1]}" target="_blank" rel="noopener">${l[0]}</a>`).join("");
    card.innerHTML = `
      ${item.feat?'<span class="c-feat-flag">★ 基準・注目</span><br>':''}
      <div class="c-top">
        <div class="c-name">${item.name}</div>
        <div class="c-pref">${item.pref}</div>
      </div>
      <div class="c-loc">${item.loc}</div>
      <div class="c-tags">${item.tags.map(t=>`<span class="ctag">${t}</span>`).join("")}</div>
      <div class="c-body">${item.body}</div>
      <div class="c-links">${links}</div>`;
    list.appendChild(card);
  });
  countEl.textContent = `${items.length} 件を表示中（全 ${DATA.length} 件）`;
  emptyEl.style.display = items.length===0 ? 'block' : 'none';
}

render();
</script>
</body>
</html>
