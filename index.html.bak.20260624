    links:[["公式予約","https://www.chillnn.com/ja/18e63c39166356"],["Instagram","https://www.instagram.com/deltahostel_akita/"]] },
  { name:"ゲストハウス梅鉢", pref:"宮城", region:"東北", loc:"仙台市",
